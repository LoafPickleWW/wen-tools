{
  "rewrites": [
    { "source": "/api/xrpl-mainnet", "destination": "https://s2-clio.ripple.com:51234/" },
    { "source": "/api/xrpl-testnet", "destination": "https://clio.altnet.rippletest.net:51234/" },
    { "source": "/api/koios-mainnet/:path*", "destination": "https://api.koios.rest/api/v1/:path*" },
    { "source": "/api/koios-preprod/:path*", "destination": "https://preprod.koios.rest/api/v1/:path*" },
    { "source": "/api/koios-preview/:path*", "destination": "https://preview.koios.rest/api/v1/:path*" },
    { "source": "/.well-known/agents.json", "destination": "/api/agents" },
    { "source": "/socket.io/(.*)", "destination": "https://wen-liquid-auth.onrender.com/socket.io/$1" },
    { "source": "/attestation/(.*)", "destination": "https://wen-liquid-auth.onrender.com/attestation/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" }
      ]
    }
  ]
}
